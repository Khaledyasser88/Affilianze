{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://affilliance.runasp.net/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "http://affilliance.runasp.net/uploads/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
