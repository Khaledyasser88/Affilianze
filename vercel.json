{
  "rewrites": [
    {
      "source": "/api/proxy(.*)",
      "destination": "/api/proxy$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/proxy?prefix=api&path=$1"
    },
    {
      "source": "/backend-api/(.*)",
      "destination": "/api/proxy?prefix=api&path=$1"
    },
    {
      "source": "/cv-api/(.*)",
      "destination": "https://swordha-cvanalysis.hf.space/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
