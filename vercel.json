{
  "routes": [
    {
      "src": "/api/proxy(.*)",
      "dest": "/api/proxy$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/proxy?prefix=api&path=$1"
    },
    {
      "src": "/backend-api/(.*)",
      "dest": "/api/proxy?prefix=api&path=$1"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/api/proxy?prefix=uploads&path=$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
