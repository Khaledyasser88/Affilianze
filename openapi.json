{"openapi":"3.1.0","info":{"title":"AI Graduation Project — Unified API","description":"Single endpoint for all AI microservices.\n\n| Prefix | Service |\n|--------|--------|\n| `/api/v1/id/...` | Egyptian ID Verification |\n| `/api/v1/personality/...` | MBTI Personality Analysis |\n| `/api/v1/cv/...` | CV Generator |\n","version":"1.0.0"},"paths":{"/api/v1/id/verify-id":{"post":{"tags":["ID Verification"],"summary":"Verify an Egyptian National ID card","description":"Upload an image of an Egyptian National ID card.\nReturns the extracted personal data and a **verified** flag.","operationId":"verify_id_api_v1_id_verify_id_post","requestBody":{"content":{"multipart/form-data":{"schema":{"$ref":"#/components/schemas/Body_verify_id_api_v1_id_verify_id_post"}}},"required":true},"responses":{"200":{"description":"Extracted ID data and verification status","content":{"application/json":{"schema":{"$ref":"#/components/schemas/IDVerificationResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/v1/personality/analyze-personality":{"post":{"tags":["Personality Analysis"],"summary":"Analyze personality and get marketing recommendations","description":"Submit 40 yes/no answers to receive MBTI type, Big Five mapping,\nand recommended marketing categories.","operationId":"analyze_personality_api_v1_personality_analyze_personality_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/PersonalityAnswersRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/PersonalityAnalysisResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/v1/personality/questions":{"get":{"tags":["Personality Analysis"],"summary":"Get the list of 40 personality questions","description":"Returns all 40 questions so the frontend can render the questionnaire dynamically.","operationId":"get_questions_api_v1_personality_questions_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/api/v1/cv/generate-cv":{"post":{"tags":["CV Generator"],"summary":"Generate an ATS-friendly CV","description":"Accepts structured CV data and returns ATS-optimized CV text,\nscore, breakdown, suggestions, and a PDF download URL.","operationId":"generate_cv_api_v1_cv_generate_cv_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/CVGenerateRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/CVGenerateResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/v1/cv/download-cv/{filename}":{"get":{"tags":["CV Generator"],"summary":"Download the generated PDF CV","description":"Download a previously generated PDF CV by filename.","operationId":"download_cv_api_v1_cv_download_cv__filename__get","parameters":[{"name":"filename","in":"path","required":true,"schema":{"type":"string","title":"Filename"}}],"responses":{"200":{"description":"Successful Response"},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/health":{"get":{"tags":["Health"],"summary":"Health","operationId":"health_health_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/services":{"get":{"tags":["Health"],"summary":"Services","operationId":"services_services_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}}},"components":{"schemas":{"ATSBreakdown":{"properties":{"section_completeness":{"type":"i